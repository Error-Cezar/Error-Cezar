---
import { getCollection, render } from "astro:content";
import type { ContentEntry } from "../types";
import Layout from "./Layout.astro";

interface Props {
  entry: ContentEntry;
}

const { entry } = Astro.props;

const { Content, headings } = await render(entry);

const formattedDate = new Date(entry.data.pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.image?.src}
>
  <article id="detail-post">
    <header class="detail-header">
      <h1>{entry.data.title}</h1>
      <p class="detail-description">{entry.data.description}</p>

      <div class="detail-meta">
        <time datetime={entry.data.pubDate.toString()}>{formattedDate}</time>

        {
          entry.data.tags.length > 0 && (
            <div class="detail-tags">
              {entry.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }
      </div>

      {
        entry.data.image && (
          <div class="detail-image">
            <img
              src={entry.data.image.src}
              alt={entry.data.image.alt}
              loading="lazy"
            />
          </div>
        )
      }
    </header>

    <div class="detail-content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  #detail-post {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .detail-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--primary-color);
  }

  .detail-header h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem 0;
    color: var(--primary-color);
  }

  .detail-description {
    font-size: 1.1rem;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    line-height: 1.8;
  }

  .detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  time {
    font-size: 0.9rem;
    color: var(--secondary-color);
    font-weight: 600;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    background-color: var(--primary-color-dark);
    color: var(--primary-color);
    border: 1px solid var(--primary-color);
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .tag:hover {
    background-color: var(--primary-color);
    color: var(--primary-color-dark);
  }

  .detail-image {
    width: 100%;
    margin: 2rem 0;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .detail-content {
    font-size: 1rem;
    line-height: 1.8;
  }

  .detail-content :global(h2) {
    font-size: 1.8rem;
    color: var(--primary-color);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .detail-content :global(h3) {
    font-size: 1.3rem;
    color: var(--secondary-color);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .detail-content :global(h4) {
    font-size: 1.1rem;
    color: var(--primary-color);
    margin-top: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .detail-content :global(p) {
    margin-bottom: 1rem;
  }

  .detail-content :global(ul),
  .detail-content :global(ol) {
    margin: 1rem 0 1rem 1.5rem;
  }

  .detail-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .detail-content :global(code) {
    background-color: var(--primary-color-dark);
    color: var(--primary-color);
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .detail-content :global(pre) {
    background-color: var(--primary-color-dark);
    color: var(--primary-color);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .detail-content :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
  }

  .detail-content :global(blockquote) {
    border-left: 4px solid var(--primary-color);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--secondary-color);
    font-style: italic;
  }

  .detail-content :global(a) {
    color: var(--secondary-color);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .detail-content :global(a:hover) {
    color: var(--primary-color);
  }

  .detail-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .detail-content :global(th),
  .detail-content :global(td) {
    border: 1px solid var(--primary-color);
    padding: 0.75rem;
    text-align: left;
  }

  .detail-content :global(th) {
    background-color: var(--primary-color-dark);
    color: var(--primary-color);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    #detail-post {
      padding: 1rem;
    }

    .detail-header h1 {
      font-size: 1.8rem;
    }

    .detail-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .detail-content :global(h2) {
      font-size: 1.4rem;
    }

    .detail-content :global(h3) {
      font-size: 1.1rem;
    }
  }
</style>
