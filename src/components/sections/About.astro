---
import { socials } from "../../data/socials";
import { aboutMe } from "../../data/aboutMe";
---

<section id="about">
  <h2>About me</h2>
  <article>
    <div class="about-profile">
      <picture>
        <img
          src={aboutMe.profile.picture}
          alt={aboutMe.profile.altText}
          loading="lazy"
          width="200"
          height="200"
        />
      </picture>
      <div class="social-media">
        {
          socials.map((value) => (
            <a href={value.link} target="_blank" rel="noopener noreferrer">
              <svg
                class="social-icon"
                viewBox="0 0 24 24"
                width="32"
                height="32"
                set:html={value.icon.svg}
              />
              <span class="sr-only">{value.name}</span>
            </a>
          ))
        }
      </div>
    </div>
    <div class="about-content">
      <h3>{aboutMe.name}</h3>
      {aboutMe.bio.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</section>

<style>
  #about {
    width: 100%;
    article {
      border-radius: 15px;
      background-color: var(--primary-color-dark);
      margin-bottom: 20px;
      display: flex;
      gap: 29px;
      padding: 20px;
      max-width: 800px;
      margin: 0 auto;
      @media (max-width: 768px) {
        flex-wrap: wrap;
        flex-direction: column;
        align-items: center;
      }
      .about-profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        width: 100%;
        padding: 10px;
        picture {
          overflow: hidden;
          max-width: 250px;
          height: auto;
          border: 2px solid var(--primary-color);

          border-radius: 30px;
        }

        a {
          color: #fff;
          transition: color 0.2s;
          position: relative;
          &:hover {
            color: var(--primary-color);
          }

          &:hover span.sr-only {
            padding: 0 5px;
            background: var(--secundary-color);
            text-decoration: underline;
            opacity: 1;
          }
        }
      }
      .about-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
    }
  }

  span.sr-only {
    position: absolute;
    right: -20px;
    bottom: -16px;
    opacity: 0;
  }
  .social-media {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 1rem;
    justify-items: center;
    justify-content: center;
  }

  .social-icon {
    width: 32px;
    height: 32px;
    fill: currentColor;
  }
</style>
