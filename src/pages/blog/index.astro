---
import { getCollection } from "astro:content";
import Layout from "../../Layouts/ListLayout.astro";

const projects = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => p);
---

<Layout
  title="Blog"
  description="All of my yaps in a single place, favorite place of stalkers"
  redirect="blog"
  entries={projects}
/>
